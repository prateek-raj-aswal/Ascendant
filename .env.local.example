# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PostgreSQL (Docker)
POSTGRES_USER=ascendant
POSTGRES_PASSWORD=ascendant_dev
POSTGRES_DB=ascendant
DATABASE_URL=postgresql://ascendant:ascendant_dev@localhost:5432/ascendant

# Redis (Docker)
REDIS_PASSWORD=ascendant_dev
REDIS_URL=redis://:ascendant_dev@localhost:6379

# API server
API_PORT=3001
API_URL=http://localhost:3001

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here
